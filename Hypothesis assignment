    {
      "cell_type": "markdown",
      "source": [
        "## Step 8: Conclusion"
      ],
      "metadata": {
        "id": "2FBbU5BHI-BM"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "if decision == \"Reject H0\":\n",
        "    conclusion = (\"There is strong evidence at the 5% significance level \"\n",
        "                  \"to support the restaurant owners' claim that weekly operating \"\n",
        "                  \"costs are higher than predicted by the model.\")\n",
        "else:\n",
        "    conclusion = (\"There is not enough evidence at the 5% significance level \"\n",
